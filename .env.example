# =============================================================================
# Copy to .env.local — see docs/ENV.md for what goes where
# =============================================================================

# -----------------------------------------------------------------------------
# LOCAL → Next.js only (bun dev / Vercel). Not uploaded to Convex or Clerk.
# -----------------------------------------------------------------------------
# Pull Clerk keys: bun run env:clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Written by `npx convex dev` when you link a deployment
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# Production: https://facets.adityamer.dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Verify context search (browser → Exa / Tavily fallback). Optional but recommended.
NEXT_PUBLIC_EXA_API_KEY=
NEXT_PUBLIC_TAVILY_API_KEY=

# Razorpay → Webhooks (secret from Razorpay dashboard) → this Next app only
RAZORPAY_WEBHOOK_SECRET=
# Shared with Convex webhook mutation (push via convex:env-push)
CONVEX_WEBHOOK_SHARED_SECRET=

# -----------------------------------------------------------------------------
# UPLOAD → Convex deployment (`bun run convex:env-push`)
# OpenCode Zen — Big Pickle: https://opencode.ai/docs/zen/
# -----------------------------------------------------------------------------
CLERK_JWT_ISSUER_DOMAIN=https://YOUR.clerk.accounts.dev
OPENCODE_API_KEY=
# Same Exa key as NEXT_PUBLIC_EXA_API_KEY — server feed poll + optional reuse
EXA_API_KEY=
BIGPICKLE_MODEL=big-pickle
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
# From Razorpay → API keys (server-side checkout on Convex)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PRICE_PLUS_INR=299
RAZORPAY_PRICE_PRO_INR=799

# -----------------------------------------------------------------------------
# Clerk Dashboard (UI — not env vars you paste from this file)
# -----------------------------------------------------------------------------
# • Enable Integrations → Convex
# • JWT template named: convex
# • API keys are pulled FROM Clerk INTO section "LOCAL → Next.js" (env:clerk)