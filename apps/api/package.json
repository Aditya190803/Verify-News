{
  "name": "@verify-news/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=.env --env-file=.env.example run --watch src/index.ts",
    "start": "bun --env-file=.env --env-file=.env.example run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "test": "bun test src/lib"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@verify-news/shared": "workspace:*",
    "drizzle-orm": "^0.44.2",
    "zod": "^3.23.8",
    "hono": "^4.9.6",
    "postgres": "^3.4.7",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4",
    "@types/bun": "latest"
  }
}